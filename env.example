# ─────────────────────────────────────────────
#  LexOffice — Variables de entorno
#  Copia este archivo como .env y rellena los valores
# ─────────────────────────────────────────────

# ── FLOW.CL ────────────────────────────────────
# Obtén tus credenciales en https://app.flow.cl/app/web/login
# Para sandbox usa: https://sandbox.flow.cl/app/web/login

FLOW_API_KEY=tu_api_key_aqui
FLOW_SECRET=tu_secret_key_aqui

# ── SERVIDOR ───────────────────────────────────
NODE_ENV=development            # cambiar a 'production' en producción
PORT=3001

# URL pública de este backend (Flow necesita hacer callbacks a esta URL)
# En producción: https://api.tudominio.cl
# En desarrollo: usa ngrok → https://abc123.ngrok.io
BASE_URL=http://localhost:3001

# URL del frontend (para redirects post-pago)
# En producción: https://www.tudominio.cl
FRONTEND_URL=http://localhost:3000

# ── EMAIL (opcional) ───────────────────────────
# Configura Resend (resend.com) o SendGrid para emails automáticos
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=no-reply@lexoffice.cl
